                <div class="orbital-ring orbital-ring-1"></div>
                <div class="orbital-ring orbital-ring-2"></div>
                <div class="orbital-ring orbital-ring-3"></div>
                <div class="orbital-core"></div>
            </div>

            <div class="container">
                <span class="tagline">INSTITUTIONAL INNOVATION</span>
                <h1 class="hero-headline" id="hero-headline">Redefining Human Potential in the 21st Century</h1>
                <p class="hero-subtext">An initiative to rethink the human capability in the era of AI.</p>
                <div class="hero-actions">
                    <button class="pill-btn white">EXPLORE INSIGHTS <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 14l-7 7-7-7M12 21V3"></path></svg></button>
