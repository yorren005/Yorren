                        </svg>
                        <!-- MIT -->
                        <svg class="proof-logo" viewBox="0 0 60 30" fill="currentColor">
                            <text x="5" y="22" font-family="Arial, sans-serif" font-weight="800" font-size="22" letter-spacing="0.05em">MIT</text>
                        </svg>
                        <!-- Harvard -->
                        <svg class="proof-logo" viewBox="0 0 110 30" fill="currentColor">
                            <text x="5" y="22" font-family="'Times New Roman', serif" font-weight="400" font-size="20" letter-spacing="0.02em">HARVARD</text>
                        </svg>
                        <!-- OpenAI -->
                        <svg class="proof-logo" viewBox="0 0 100 30" fill="currentColor">
                            <circle cx="15" cy="15" r="7" stroke="currentColor" stroke-width="2" fill="none" />
